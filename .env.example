# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
# New key format (2025+): sb_publishable_* (anon/public) and sb_secret_* (service_role).
# Legacy JWT format (eyJ...) also still works.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# OpenAI — used for chat (4o-mini) and embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Resend — used for transactional email (profile claim invites)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=OrgChart <noreply@yourdomain.com>

# Firecrawl — used in onboarding to scrape brand colors + logo from company website
FIRECRAWL_API_KEY=fc-...

# App URL — used for magic link redirects and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
